<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.agent">

    <!-- ====================================================================== -->
    <!-- FOREGROUND SERVICE — required to keep the agent alive                  -->
    <!-- ====================================================================== -->

    <!-- Base permission — required on all API levels for startForeground() -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!--
        Android 14 (API 34) enforcement: apps targeting API 34+ MUST declare
        the exact foreground service type they use via a typed permission.

        Our agent runs local LLM inference — no standard type (location, camera,
        microphone, health, etc.) applies. We therefore use FOREGROUND_SERVICE_SPECIAL_USE.

        The <property> element below (inside <application>) provides the mandatory
        sub-type justification string for Play Store review.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- ====================================================================== -->
    <!-- PERMISSIONS FOR FileSystemTool                                         -->
    <!-- ====================================================================== -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- ====================================================================== -->
    <!-- PERMISSIONS FOR Camera                                                 -->
    <!-- ====================================================================== -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- ====================================================================== -->
    <!-- PERMISSIONS FOR SettingsTool (Shizuku)                                 -->
    <!-- ====================================================================== -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />

    <!-- ====================================================================== -->
    <!-- PERMISSIONS FOR Google Integrations & MCP                              -->
    <!-- ====================================================================== -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- POST_NOTIFICATIONS required on Android 13+ to show the foreground service notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Autonomous Agent"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AgentApp"
        android:requestLegacyExternalStorage="true">

        <!--
            Android 14+ FOREGROUND_SERVICE_SPECIAL_USE sub-type justification.
            Required for Play Store submission when using specialUse foreground type.
            Value is free-form; describe what the service does in plain language.
        -->
        <property
            android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
            android:value="local_llm_inference_gemma" />

        <!-- ================================================================== -->
        <!-- Main Entry Point                                                    -->
        <!-- ================================================================== -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Camera Capture Activity -->
        <activity
            android:name=".tools.CameraCaptureActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false" />

        <!-- ================================================================== -->
        <!-- AgentForegroundService — hosts Gemma in a persistent process       -->
        <!-- ================================================================== -->
        <!--
            android:foregroundServiceType="specialUse"
            Tells Android 14+ which typed FGS category we use.
            Must match the <uses-permission android:name="...FOREGROUND_SERVICE_SPECIAL_USE" /> above.

            android:exported="false"
            Only our own app (MainActivity) can bind to this service.
            External intents via ACTION_SUBMIT_PROMPT arrive through startService(),
            NOT through binding — so exported=false is correct and safe.

            android:stopWithTask="false"
            Keep the service alive even when the user swipes the task away,
            so background agent execution (e.g. a scheduled Tasker task) continues.
        -->
        <service
            android:name=".service.AgentForegroundService"
            android:foregroundServiceType="specialUse"
            android:exported="false"
            android:stopWithTask="false" />

        <!-- ================================================================== -->
        <!-- Accessibility Service for UIInteractTool                           -->
        <!-- ================================================================== -->
        <service
            android:name=".tools.AgentAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>
</manifest>
